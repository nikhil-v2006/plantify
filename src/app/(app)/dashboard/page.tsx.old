
"use client";

import { useState, useEffect } from "react";
import { Card, CardContent, CardHeader, CardTitle, CardDescription } from "@/components/ui/card";
import { Button } from "@/components/ui/button";
import Link from "next/link";
import { summarizeDashboardInsights } from "@/ai/flows/summarize-dashboard-insights";
import { aiCropHealthIssues } from "@/ai/flows/ai-crop-health-issues";
import { mockFieldData } from "@/lib/data";
import { Thermometer, Droplets, Wind, Sun, AlertTriangle, Bot, Loader2, RefreshCw, Moon } from "lucide-react";
import { HealthTrendChart } from "@/components/health-trend-chart";
import type { WeatherData } from "@/types";
import { useHistory } from "@/hooks/use-history";
import { useToast } from "@/hooks/use-toast";

function DashboardSummary({ weather }: { weather: WeatherData | null }) {
  const [summary, setSummary] = useState<string | null>(null);
  const [isLoading, setIsLoading] = useState(true);
  const { history } = useHistory();

  useEffect(() => {
    async function getSummary() {
      if (!weather) return;

      // Find the most recent disease from history
      const lastDisease = history.find(item => item.status === 'Diseased' || item.status === 'At Risk');

      try {
        const result = await summarizeDashboardInsights({
          soilHealth: `Approx. ${weather.humidity}% moisture`,
          temperature: `${weather.temperature}°C`,
          leafDiseases: lastDisease ? `${lastDisease.disease} detected recently` : 'No major diseases detected recently.',
          plantHealth: 'Overall health appears stable based on recent checkups.',
        });
        setSummary(result.summary);
      } catch (e) {
        console.error("Failed to get dashboard summary", e);
        setSummary("Could not load AI insights at this time.");
      } finally {
        setIsLoading(false);
      }
    }
    getSummary();
  }, [weather, history]);

  return (
    <Card className="bg-primary/5 border-primary/20">
      <CardHeader>
        <CardTitle className="flex items-center gap-2">
          <Bot className="text-primary" />
          AI-Powered Insights
        </CardTitle>
      </CardHeader>
      <CardContent>
        {isLoading || !weather ? (
            <div className="flex items-center gap-2 text-sm text-foreground/80">
                <Loader2 className="h-4 w-4 animate-spin" />
                <span>Generating insights based on current conditions...</span>
            </div>
        ) : (
            <p className="text-sm text-foreground/80">{summary}</p>
        )}
      </CardContent>
    </Card>
  );
}

function ActiveRisksSummary({ weather }: { weather: WeatherData | null }) {
  const [summary, setSummary] = useState<string | null>(null);
  const [isLoading, setIsLoading] = useState(true);
  const { history } = useHistory();

  useEffect(() => {
    async function getRisks() {
        if (!weather) return;

        const lastDisease = history.find(item => item.status === 'Diseased' || item.status === 'At Risk');
        
        try {
          const result = await aiCropHealthIssues({
            cropType: mockFieldData.cropType, // This can be made dynamic later
            fieldConditions: `Current temperature is ${weather.temperature}°C with ${weather.humidity}% humidity.`,
            leafAnalysisResults: lastDisease ? `Recent analysis showed ${lastDisease.disease}.` : 'No recent diseases detected.',
            historicalData: 'Historical data is not available yet.',
            location: weather.location,
          });
          setSummary(result.summary);
        } catch (e) {
            console.error("Failed to get active risks summary", e);
            setSummary("Could not load risk assessment at this time.");
        } finally {
            setIsLoading(false);
        }
    }
    getRisks();
  }, [weather, history]);

  return (
    <div>
        {isLoading || !weather ? (
            <div className="flex items-center gap-2 text-sm text-muted-foreground">
                <Loader2 className="h-4 w-4 animate-spin" />
                <span>Assessing risks for your location...</span>
            </div>
        ) : (
             <p className="text-sm text-muted-foreground">{summary}</p>
        )}
    </div>
  );
}

async function getWeatherData(latitude: number, longitude: number): Promise<WeatherData> {
    const response = await fetch(`https://api.open-meteo.com/v1/forecast?latitude=${latitude}&longitude=${longitude}&current=temperature_2m,relative_humidity_2m,wind_speed_10m,is_day&daily=sunshine_duration&timezone=auto`);
    if (!response.ok) {
        throw new Error('Failed to fetch weather data');
    }
    const data = await response.json();
    
    let locationName = `${latitude.toFixed(2)}, ${longitude.toFixed(2)}`;
    try {
        const geoResponse = await fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${latitude}&lon=${longitude}`);
        if (geoResponse.ok) {
            const geoData = await geoResponse.json();
            locationName = geoData.address.city || geoData.address.town || geoData.address.village || geoData.display_name;
        }
    } catch (e) {
        console.error("Reverse geocoding failed", e);
    }

    return {
        temperature: Math.round(data.current.temperature_2m),
        windSpeed: Math.round(data.current.wind_speed_10m),
        humidity: data.current.relative_humidity_2m,
        sunHours: Math.round(data.daily.sunshine_duration[0] / 3600),
        location: locationName,
        isDay: data.current.is_day === 1,
    };
}

export default function DashboardPage() {
  const { toast } = useToast();
  const [weather, setWeather] = useState<WeatherData | null>(null);
  const [isLoading, setIsLoading] = useState(true);
  const [coords, setCoords] = useState({ latitude: 18.29, longitude: 83.4 }); // Vizianagaram

  const fetchWeather = async (latitude: number, longitude: number) => {
    setIsLoading(true);
    try {
      const weatherData = await getWeatherData(latitude, longitude);
      setWeather(weatherData);
    } catch (e) {
      console.error("Failed to fetch weather data", e);
       // Fallback to mock data if API fails
      setWeather({
          temperature: 28,
          windSpeed: 10,
          humidity: 75,
          sunHours: 8,
          location: 'Vizianagaram (Mock)',
          isDay: true,
      });
    } finally {
      setIsLoading(false);
    }
  };

  const handleGetCurrentLocation = () => {
    if (!navigator.geolocation) {
      toast({
        variant: "destructive",
        title: "Location Not Supported",
        description: "Geolocation is not supported by this browser.",
      });
      return;
    }
    
    toast({ title: "Fetching your location..." });
    setIsLoading(true);

    navigator.geolocation.getCurrentPosition(
      (position) => {
        const { latitude, longitude } = position.coords;
        setCoords({latitude, longitude});
      },
      (err) => {
        console.error("Geolocation error:", err.message);
        toast({
          variant: "destructive",
          title: "Location Error",
          description: "Could not get your location. Showing default.",
        });
        // Keep the default coords
        fetchWeather(coords.latitude, coords.longitude);
      }
    );
  };
  
  useEffect(() => {
    fetchWeather(coords.latitude, coords.longitude);
  }, [coords]);


  const renderWeatherCard = (title: string, value: string, subtext: string, icon: React.ReactNode, action?: React.ReactNode) => (
    <Card>
      <CardHeader className="flex flex-row items-center justify-between space-y-0 pb-2">
        <CardTitle className="text-sm font-medium">{title}</CardTitle>
        {icon}
      </CardHeader>
      <CardContent>
        {isLoading ? (
          <Loader2 className="h-6 w-6 animate-spin" />
        ) : (
          <>
            <div className="text-2xl font-bold">{value}</div>
            <div className="flex justify-between items-center">
              <p className="text-xs text-muted-foreground">{subtext}</p>
              {action}
            </div>
          </>
        )}
      </CardContent>
    </Card>
  );

  return (
    <div className="space-y-6">
       <h1 className="text-3xl font-bold tracking-tight">Dashboard</h1>
       <div className="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
        {renderWeatherCard(
            "Temperature", 
            `${weather?.temperature ?? '...'}°C`, 
            `in ${weather?.location ?? '...'}`, 
            <Thermometer className="h-4 w-4 text-muted-foreground" />,
            <Button variant="ghost" size="icon" className="h-6 w-6 -mr-2" onClick={handleGetCurrentLocation} disabled={isLoading}>
                {isLoading ? <Loader2 className="h-3 w-3 animate-spin" /> : <RefreshCw className="h-3 w-3" />}
            </Button>
        )}
        {renderWeatherCard("Soil Moisture", `${weather?.humidity ?? '...'}%`, "Current humidity", <Droplets className="h-4 w-4 text-muted-foreground" />)}
        {renderWeatherCard("Wind Speed", `${weather?.windSpeed ?? '...'} km/h`, "Current wind", <Wind className="h-4 w-4 text-muted-foreground" />)}
        
        {weather?.isDay ? (
            renderWeatherCard("Sunlight", `${weather?.sunHours ?? '...'}h`, "of daily sunlight", <Sun className="h-4 w-4 text-muted-foreground" />)
        ) : (
            renderWeatherCard("Night", "Night", "Currently dark", <Moon className="h-4 w-4 text-muted-foreground" />)
        )}
      </div>

      <div className="grid gap-6 lg:grid-cols-3">
        <div className="lg:col-span-2 space-y-6">
          <DashboardSummary weather={weather} />
        </div>
        <div className="space-y-6">
          <Card className="bg-accent/10 border-accent/30">
            <CardHeader>
              <CardTitle className="flex items-center gap-2"><AlertTriangle className="text-accent" /> Active Risks</CardTitle>
            </CardHeader>
            <CardContent className="space-y-4">
              <ActiveRisksSummary weather={weather}/>
              <Button asChild className="w-full" variant="outline">
                <Link href="/analysis">Analyze Leaf Sample</Link>
              </Button>
              <Button asChild className="w-full">
                <Link href="/reports">Generate Full Report</Link>
              </Button>
            </CardContent>
          </Card>
          <HealthTrendChart />
        </div>
      </div>
    </div>
  );
}
