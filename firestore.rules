/**
 * @description: This ruleset enforces a strict user-ownership model for user profile data stored in Firestore. Each user can only access their own profile data, and no listing of all users is allowed.
 * @dataStructure: All user data is stored under the `/users/{userId}` path, where `{userId}` corresponds to the authenticated user's UID.
 * @keySecurityDecisions:
 *   - User listing is explicitly disallowed to protect user privacy.
 *   - Only the authenticated user can create, read, update, or delete their own profile data.
 *   - The rules validate that the `userId` in the path matches the `id` field in the document to prevent unauthorized access.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description: Manages access to user profile documents. Each user can only access their own profile.
     * @path: /users/{userId}
     * @allow: User with UID 'user123' can (create), (get), (update), or (delete) the document at /users/user123.
     * @deny: User with UID 'user456' cannot (create), (get), (update), or (delete) the document at /users/user123.
     * @principle: Enforces document ownership for all operations on user profiles.
     */
    match /users/{userId} {
      // Helper function to check if the user is signed in
      function isSignedIn() {
        return request.auth != null;
      }

      // Helper function to check if the authenticated user is the owner of the document
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      // Helper function to check if the authenticated user is the owner of the existing document
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      // Allow read access if the user is the owner
      allow get: if isOwner(userId);
      // Only the owner can list their own user document (effectively disabling listing of all users)
      allow list: if false;

      // Allow create access if the user is the owner and the user ID in the request data matches the path
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.id == userId;

      // Allow update access if the user is the owner and the user ID in the merged data matches the existing ID
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;

      // Allow delete access if the user is the owner
      allow delete: if isExistingOwner(userId);
    }
  }
}